{
  "name": "@emgeebee/phone_cli",
  "version": "3.3.3",
  "description": "mats useful cli scripts",
  "main": "dist/phone_cli.js",
  "bin": {
    "l": "./dist/phone_cli.js",
    "phone-cli": "./dist/phone_cli.js",
    "ball": "./dist/ball.js",
    "cal": "./dist/cal.js",
    "w": "./dist/w.js",
    "cric": "./dist/cric.js",
    "bday": "./dist/bday.js",
    "octo": "./dist/octo.js",
    "money": "./dist/money.js",
    "cmd": "./dist/cmd.js",
    "fuel": "./dist/fuel.js",
    "r": "./dist/r.js",
    "temp": "./dist/temp.js",
    "solar": "./dist/solar.js",
    "i": "./dist/i.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run typecheck && pnpm run bundle",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bundle": "rm -rf dist && mkdir -p dist && esbuild phone_cli.ts i.ts ball.ts cal.ts w.ts cric.ts bday.ts octo.ts money.ts cmd.ts fuel.ts r.ts temp.ts solar.ts --bundle --platform=node --format=cjs --target=node20 --outdir=dist",
    "phone_cli": "pnpm build && node dist/phone_cli.js",
    "ball": "pnpm build && node dist/ball.js",
    "phone-cal": "pnpm build && node dist/cal.js",
    "cal": "pnpm build && node dist/cal.js",
    "w": "pnpm build && node dist/w.js",
    "cric": "pnpm build && node dist/cric.js",
    "bday": "pnpm build && node dist/bday.js",
    "octo": "pnpm build && node dist/octo.js",
    "money": "pnpm build && node dist/money.js",
    "cmd": "pnpm build && node dist/cmd.js",
    "fuel": "pnpm build && node dist/fuel.js",
    "r": "pnpm build && node dist/r.js",
    "temp": "pnpm build && node dist/temp.js",
    "solar": "pnpm build && node dist/solar.js",
    "i": "pnpm build && node dist/i.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "string-width": "4.2.3",
    "strip-ansi": "6.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0"
}
